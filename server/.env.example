# =========================
# Runtime
# =========================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info


# =========================
# Binance Futures API
# =========================
# Leave empty for public market data only.
# Required for trading / account endpoints in production.
BINANCE_BASE_URL=https://fapi.binance.com
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Network / retry behaviour
BINANCE_TIMEOUT_MS=12000
BINANCE_RETRY=5
BINANCE_BACKOFF_MS=220
BINANCE_MAX_BACKOFF_MS=20000


# =========================
# Scanner Defaults
# Used when frontend does not provide config
# =========================
SP_UNIVERSE=40
SP_BATCH=8
SP_THROTTLE=140
SP_INT_1M=45
SP_INT_5M=120
SP_BACKFILL=180
SP_SYMBOL_COOLDOWN=6500
SP_EMA_FAST=34
SP_EMA_SLOW=144
SP_ATR_LEN=14
SP_ATR_FACTOR=1.5
SP_RR=2.0
SP_QTY=1
SP_RISK_MULT=1.0
SP_PNL_POLL=3
SP_PX_MODE=mark


# =========================
# Feature Flags
# =========================
ENABLE_WS=true
ENABLE_LIVE_PNL=true


# =========================
# Telegram Sync (backend only)
# Leave empty to disable Telegram mirroring.
# Use the numeric chat ID when available.
# =========================
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ID=
TELEGRAM_CHAT_LINK=
TELEGRAM_CHAT_ID=
TELEGRAM_SYNC_STARTUP_PROBE=false
TELEGRAM_SYNC_STARTUP_PROBE_TEXT=SignalPulse Telegram sync probe


# =========================
# SQLite
# Leave empty to use default:
# server/data.sqlite
# =========================
SQLITE_PATH=
